# KLineChart 部署配置
# 复制此文件为 .env.deploy 并修改配置

# ============================================
# 端口配置
# ============================================

# 前端端口
PORT=3000

# Baostock 后端端口
BAOSTOCK_PORT=8000

# ============================================
# 外部服务（可选）
# ============================================

# AKTools 地址（如果在其他服务器或宿主机运行）
# AKTOOLS_URL=http://host.docker.internal:8080/

# ============================================
# Docker 配置
# ============================================
COMPOSE_PROJECT_NAME=klinechart-demo

# Baostock 后端地址（容器间通信用服务名）
BAOSTOCK_URL=http://stockbao-backend:8000/

# AKTools 地址（如果未配置则留空或默认本地）
AKTOOLS_URL=http://127.0.0.1:8080/