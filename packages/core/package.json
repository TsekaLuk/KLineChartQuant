{
  "name": "@klinechart-quant/core",
  "version": "0.1.0-alpha.0",
  "description": "Headless K-line chart engine + reactive controllers. Zero framework dependencies.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./reactivity": {
      "types": "./dist/reactivity/index.d.ts",
      "import": "./dist/reactivity/index.js"
    },
    "./controllers": {
      "types": "./dist/controllers/index.d.ts",
      "import": "./dist/controllers/index.js"
    },
    "./render": {
      "types": "./dist/render/index.d.ts",
      "import": "./dist/render/index.js"
    },
    "./scale": {
      "types": "./dist/scale/index.d.ts",
      "import": "./dist/scale/index.js"
    },
    "./scene": {
      "types": "./dist/scene/index.d.ts",
      "import": "./dist/scene/index.js"
    },
    "./replay": {
      "types": "./dist/replay/index.d.ts",
      "import": "./dist/replay/index.js"
    },
    "./alerts": {
      "types": "./dist/alerts/index.d.ts",
      "import": "./dist/alerts/index.js"
    },
    "./chartTypes": {
      "types": "./dist/chartTypes/index.d.ts",
      "import": "./dist/chartTypes/index.js"
    },
    "./components/volumeProfile": {
      "types": "./dist/components/volumeProfile/index.d.ts",
      "import": "./dist/components/volumeProfile/index.js"
    },
    "./components/orderBookHeatmap": {
      "types": "./dist/components/orderBookHeatmap/index.d.ts",
      "import": "./dist/components/orderBookHeatmap/index.js"
    },
    "./components/footprint": {
      "types": "./dist/components/footprint/index.d.ts",
      "import": "./dist/components/footprint/index.js"
    },
    "./components/anchoredVwap": {
      "types": "./dist/components/anchoredVwap/index.d.ts",
      "import": "./dist/components/anchoredVwap/index.js"
    },
    "./components/mtfOverlay": {
      "types": "./dist/components/mtfOverlay/index.d.ts",
      "import": "./dist/components/mtfOverlay/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "size-limit",
    "lint:publish": "publint --strict .",
    "lint:types": "attw --pack ."
  },
  "size-limit": [
    {
      "name": "core (entry, pre-build src measurement)",
      "path": "src/index.ts",
      "limit": "30 KB",
      "gzip": true
    }
  ],
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.0",
    "@size-limit/preset-small-lib": "^11.1.6",
    "publint": "^0.3.0",
    "size-limit": "^11.1.6",
    "typescript": "~5.6.0",
    "vitest": "^4.1.5"
  }
}
