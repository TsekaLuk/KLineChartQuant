{
  "name": "@363045841yyt/klinechart-react",
  "version": "0.0.0",
  "description": "React bindings for @363045841yyt/klinechart-core. Idiomatic hooks, SSR-safe, tree-shakable.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "scripts": {
    "dev": "vite --config preview/vite.config.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "size-limit",
    "lint:publish": "publint --strict .",
    "lint:types": "attw --pack ."
  },
  "size-limit": [
    {
      "name": "react (entry, pre-build src measurement)",
      "path": "src/index.ts",
      "limit": "8 KB",
      "gzip": true,
      "ignore": [
        "react",
        "react-dom",
        "@363045841yyt/klinechart-core"
      ]
    }
  ],
  "peerDependencies": {
    "@363045841yyt/klinechart-core": "workspace:*",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "publint": "^0.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "size-limit": "^12.1.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  }
}
