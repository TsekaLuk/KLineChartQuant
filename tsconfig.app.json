{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "packages/**/*.ts",
    "packages/**/*.vue"
  ],
  "exclude": [
    "**/__tests__/**",
    "**/node_modules",
    "**/dist"
  ],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ESNext",
    "useDefineForClassFields": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./packages/core/src/*"],
      "@/core/*": ["./packages/core/src/engine/*"]
    },
    "types": [
      "vite/client",
      "unplugin-icons/types/vue"
    ]
  }
}